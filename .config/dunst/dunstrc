[global]
    ### Display & Geometry ###
    monitor = 0
    follow = none
    
    origin = top-right
    offset = 30 # 가로 및 세로 간격 30px

    transparency = 95
    padding = 8
    horizontal_padding = 10
    separator_height = 2
    corner_radius = 10

    ### Appearance ###
    font = monospace 10
    
    # show_icons 옵션이 제거되었습니다. 
    # 아이콘을 표시하려면 기본값이 true이므로 이 옵션을 완전히 제거합니다.

    # frame_width는 그대로 사용 가능합니다.
    frame_width = 1
    frame_color = "#3B4252"

    ### Behavior ###
    notification_limit = 5
    # startup_notification 옵션이 제거되었습니다.

    ### Colors (Nord Palette) ###
[urgency_low]
    background = "#3B4252"
    foreground = "#E5E9F0"

[urgency_normal]
    background = "#4C566A"
    foreground = "#E5E9F0"

[urgency_critical]
    background = "#BF616A"
    foreground = "#E5E9F0"
